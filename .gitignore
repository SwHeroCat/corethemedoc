# 1. Ignore all files and folders in the root directory
/*

# 2. STRICTLY IGNORE the .pi folder and all its subfolders/contents
/.pi/
/.pi/**

# 3. Allow Git to look inside other directories (to find 'docs/')
!/*/

# 4. Do not ignore the 'docs' folder itself
!/docs/

# 5. Do not ignore any content or subfolders inside 'docs'
!/docs/**

# 6. Ensure this .gitignore file itself is tracked and committed
!.gitignore